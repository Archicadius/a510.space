        <script>
            (function () {
                // Helper tokens we manage ourselves on cards.
                var SIZE_CLASSES = ['big','medium','small','xxl'];
                var SIDE_CLASSES = ['is-reversed','is-left','is-right'];

                // Two mirrored building blocks. Each fills a 6-wide × 3-row
                // rectangle of the grid with no holes:
                //
                //   BLOCK_A:   L L L L s s
                //              L L L L s s
                //              M M M M M M
                //
                //   BLOCK_B:   s s L L L L
                //              s s L L L L
                //              M M M M M M
                //
                // Each entry is { size, side? } where side controls the
                // caption orientation / explicit grid placement.
                var BLOCK_A = [
                    { size:'big' },
                    { size:'small', side:'right' },  // caption on the inside (left edge of card)
                    { size:'small', side:'right' },
                    { size:'medium' },
                    { size:'medium' }
                ];
                var BLOCK_B = [
                    { size:'small', side:'left' },   // caption on the inside (right edge of card)
                    { size:'small', side:'left' },
                    { size:'big',   side:'right' },  // big pinned to columns 3..6
                    { size:'medium' },
                    { size:'medium' }
                ];

                // Tail patterns (when N is not divisible by 5).
                // _A: big-on-the-left variant.  _B: mirror.
                var TAIL_A = {
                    1: [{ size:'xxl' }],
                    2: [{ size:'medium' }, { size:'medium' }],
                    3: [{ size:'big' }, { size:'small', side:'right' }, { size:'small', side:'right' }],
                    4: [{ size:'big' }, { size:'small', side:'right' }, { size:'small', side:'right' }, { size:'xxl' }]
                };
                var TAIL_B = {
                    1: [{ size:'xxl' }],
                    2: [{ size:'medium' }, { size:'medium' }],
                    3: [{ size:'small', side:'left' }, { size:'small', side:'left' }, { size:'big', side:'right' }],
                    4: [{ size:'small', side:'left' }, { size:'small', side:'left' }, { size:'big', side:'right' }, { size:'xxl' }]
                };

                // Build a full pattern array of length N by alternating A/B blocks
                // and picking the mirrored tail variant.
                function computePattern(n) {
                    if (n <= 0) return [];
                    if (n < 5) return TAIL_A[n].slice();
                    var pat = [];
                    var full = Math.floor(n / 5);
                    var rem = n % 5;
                    for (var i = 0; i < full; i++) {
                        pat = pat.concat(i % 2 === 0 ? BLOCK_A : BLOCK_B);
                    }
                    if (rem > 0) {
                        // If the last full block was A (full odd), use mirrored tail.
                        var useMirror = (full % 2 === 1);
                        pat = pat.concat((useMirror ? TAIL_B : TAIL_A)[rem]);
                    }
                    return pat;
                }

                var params = new URLSearchParams(window.location.search);
                var cat = (params.get('cat') || '').toLowerCase();
                var valid = ['residential','commercial','interior','social','masterplanning'];
                var main = document.querySelector('main');
                var menuLinks = document.querySelectorAll('.filter-menu a');
                var cards = Array.prototype.slice.call(
                    document.querySelectorAll('.complex-grid > a')
                );

                // Snapshot original class list once.
                cards.forEach(function (c) {
                    if (!c.dataset.originalClass) {
                        c.dataset.originalClass = c.className;
                    }
                });

                function rebuildClasses(card, spec) {
                    var keep = card.dataset.originalClass.split(/\s+/).filter(function (cls) {
                        return SIZE_CLASSES.indexOf(cls) === -1 &&
                               SIDE_CLASSES.indexOf(cls) === -1;
                    });
                    keep.push(spec.size);
                    if (spec.size === 'small' && spec.side === 'right') keep.push('is-reversed');
                    if (spec.size === 'small' && spec.side === 'left')  keep.push('is-left');
                    if (spec.size === 'big'   && spec.side === 'right') keep.push('is-right');
                    return keep.join(' ').trim();
                }

                if (valid.indexOf(cat) !== -1) {
                    main.setAttribute('data-active-cat', cat);
                    menuLinks.forEach(function (a) {
                        var u = new URL(a.getAttribute('href'), window.location.href);
                        if ((u.searchParams.get('cat') || '').toLowerCase() === cat) {
                            a.classList.add('is-active');
                        }
                    });

                    var visible = cards.filter(function (c) {
                        return (c.getAttribute('data-category') || '') === cat;
                    });
                    var pattern = computePattern(visible.length);
                    visible.forEach(function (card, i) {
                        var spec = pattern[i] || { size:'medium' };
                        card.className = rebuildClasses(card, spec);
                    });
                    // Hidden cards keep their originals; CSS hides them via display:none.
                } else {
                    // "All" — restore originals.
                    cards.forEach(function (c) { c.className = c.dataset.originalClass; });
                    var first = menuLinks[0];
                    if (first) first.classList.add('is-active');
                }
            })();
        </script>
